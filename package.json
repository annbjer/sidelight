{
  "name": "sidelight",
  "version": "0.5.1",
  "description": "Read-only project-awareness TUI for a terminal split pane — files, git, search, preview, and optional PI session metadata",
  "type": "module",
  "bin": {
    "sidelight": "dist/src/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test \"dist/test/*.test.js\"",
    "start": "node dist/src/index.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check && npm test"
  },
  "dependencies": {
    "@mariozechner/pi-tui": "^0.73.1"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "author": "Daniel Annbjer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/annbjer/sidelight.git"
  },
  "homepage": "https://github.com/annbjer/sidelight#readme",
  "bugs": {
    "url": "https://github.com/annbjer/sidelight/issues"
  },
  "keywords": [
    "tui",
    "terminal",
    "git",
    "sidecar",
    "agent",
    "pi",
    "local-first",
    "read-only",
    "pi-package"
  ],
  "files": [
    "dist/src",
    "dist/extension",
    "src",
    "extension",
    "PHILOSOPHY.md"
  ],
  "pi": {
    "extensions": [
      "./extension"
    ],
    "image": "https://raw.githubusercontent.com/annbjer/sidelight/main/assets/1-hero-dark.png"
  }
}
